{
  "extends": [
    "config:base"
  ],
  "labels": [
    "dependencies",
    "github-actions"
  ],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "matchFileNames": [
        "**/.github/workflows/**/*.ya?ml",
        "**/.github/actions/**/*.ya?ml"
      ],
      "separateMinorPatch": true,
      "enabled": true
    },
    {
      "matchManagers": ["github-actions"],
      "excludePackagePrefixes": ["ministryofjustice/hmpps-github-actions"],
      "pinDigests": true
    }
  ]
}